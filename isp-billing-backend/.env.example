APP_NAME="NetBilling ISP Management"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://yourdomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=billing_db
DB_USERNAME=billing_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="billing@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================
# SECURITY
# ========================
HTTPS_ONLY=true
FORCE_HTTPS=true
APP_STRICT_SECURITY=true

# ========================
# SANCTUM TOKEN SECURITY
# ========================
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SANCTUM_COOKIE_SECURE=true
SANCTUM_COOKIE_HTTP_ONLY=true
SANCTUM_COOKIE_SAME_SITE=lax
SANCTUM_TOKEN_EXPIRATION=60

# ========================
# RATE LIMITING
# ========================
API_RATE_LIMIT=60
API_RATE_WINDOW=1

# ========================
# ADMIN USER (Change immediately after setup!)
# ========================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@netbilling.local
ADMIN_PASSWORD=change-me-immediately

VITE_APP_NAME="${APP_NAME}"
